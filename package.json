{
	"name": "pota-docs",
	"description": "pota docs",
	"version": "0.1.5",
	"author": "Tito Bouzout",
	"type": "module",
	"homepage": "https://pota.quack.uy/",
	"scripts": {
		"dev": "kompiler",
		"update": "npm update --include=dev --save && npm run dev"
	},
	"dependencies": {
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-javascript": "^6.2.5",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.41.0",
		"@types/css-modules": "^1.0.5",
		"@types/node": "^25.5.0",
		"@typescript/vfs": "^1.6.4",
		"codemirror": "^6.0.2",
		"color-bits": "^1.1.1",
		"dom-flair": "file:../../../../dom-flair",
		"fflate": "^0.8.2",
		"kompiler": "file:../../../../kompiler",
		"monaco-editor": "^0.55.1",
		"pota": "file:../../../pota",
		"tm-textarea": "file:../../../../solid/tm-textarea"
	},
	"kompiler": {
		"watch": [
			"src/release.js",
			"../../pota/src/"
		],
		"node": [
			{
				"input": "./src/pages/tests/node.js",
				"watch": [
					"../../pota/"
				],
				"ignore": [
					"coverage",
					".tmp"
				]
			}
		],
		"builds": [
			{
				"input": [
					"src/index.jsx"
				],
				"output": "src/dist/",
				"map": [
					[
						"/src/node_modules",
						"/node_modules"
					]
				],
				"minified": false,
				"treeshake": true,
				"babel": {
					"presets": [
						[
							"pota/babel-preset"
						]
					]
				}
			},
			{
				"input": [
					"src/pages/@playground/preview/index.jsx"
				],
				"output": "src/dist/preview/",
				"minified": false,
				"treeshake": false,
				"root": false
			},
			{
				"input": [
					"src/pages/benchmark/dev/index.jsx"
				],
				"watch": [
					"../../pota/src/"
				],
				"output": "src/pages/benchmark/dev/main.js",
				"minified": false,
				"treeshake": true,
				"root": false,
				"babel": {
					"presets": [
						[
							"pota/babel-preset"
						]
					]
				}
			},
			{
				"input": [
					"src/pages/benchmark/dev-swap/index.jsx"
				],
				"output": "src/pages/benchmark/dev-swap/main.js",
				"minified": false,
				"treeshake": true,
				"root": false,
				"babel": {
					"presets": [
						[
							"pota/babel-preset"
						]
					]
				}
			},
			{
				"input": [
					"src/pages/benchmark/regular/index.jsx"
				],
				"output": "src/pages/benchmark/regular/main.js",
				"minified": false,
				"treeshake": true,
				"root": false,
				"babel": {
					"presets": [
						[
							"pota/babel-preset"
						]
					]
				}
			},
			{
				"input": [
					"src/pages/benchmark/xml/index.jsx"
				],
				"output": "src/pages/benchmark/xml/main.js",
				"minified": false,
				"treeshake": true,
				"root": false,
				"babel": {
					"presets": [
						[
							"pota/babel-preset"
						]
					]
				}
			}
		]
	},
	"prettier": {
		"printWidth": 70,
		"useTabs": true,
		"semi": false,
		"singleQuote": true,
		"quoteProps": "as-needed",
		"jsxSingleQuote": false,
		"trailingComma": "all",
		"bracketSpacing": true,
		"bracketSameLine": false,
		"arrowParens": "avoid",
		"proseWrap": "never",
		"endOfLine": "lf",
		"singleAttributePerLine": false
	},
	"devDependencies": {
		"typescript": "^6.0.2"
	}
}
