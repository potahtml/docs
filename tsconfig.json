{
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,

    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,

    "module": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,

    "jsx": "preserve",
    "jsxImportSource": "pota",

    "types": [
      "pota",
      "dom-flair",
      "tm-textarea",
      "node",
      "@types/css-modules"
    ]
  },
  "exclude": [
    "./src/dist/*",
    "./src/pages/benchmark/*",
    "./src/pages/@articles/anatomy/*",
    "./src/pages/tests/mutable*",
    "node_modules"
  ]
}
