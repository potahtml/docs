{
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "./dist",

    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "skipLibCheck": true,

    "module": "NodeNext",
    "target": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    "jsx": "preserve",
    "jsxImportSource": "pota",

    "sourceMap": true,

    "types": [
      "pota",
      "dom-flair",
      "tm-textarea",
      "node",
      "@types/css-modules"
    ]
  },
  "exclude": ["./src/dist/*", "node_modules"]
}
